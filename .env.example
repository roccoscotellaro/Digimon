# Copia questi valori nelle Environment Variables del progetto Vercel.
# NON committare mai un file .env reale con i valori veri.

# Da Supabase: Project Settings -> API -> Project URL
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Da Supabase: Project Settings -> API -> service_role key (SEGRETA, non la "anon" key)
SUPABASE_SERVICE_KEY=eyJ...

# Da Google AI Studio (aistudio.google.com) -> Get API Key. Gratuito, nessuna carta di credito.
GEMINI_API_KEY=AIza...
